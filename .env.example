# OpenAI — required for chat completions
OPENAI_API_KEY=

# Exa — required for catering and vendor search
EXA_API_KEY=

# Airbyte Context Store — optional, preferred read path for connected source data
# AIRBYTE_API_KEY can be a cached application token. For long-running local dev,
# prefer AIRBYTE_CLIENT_ID / AIRBYTE_CLIENT_SECRET so the app can refresh tokens.
AIRBYTE_CONNECTOR_ID=
AIRBYTE_CLIENT_ID=
AIRBYTE_CLIENT_SECRET=
AIRBYTE_API_KEY=

# VAPI — optional, enables AI outbound phone calls to vendors/caterers
# Get these from https://dashboard.vapi.ai
# Configure webhook URL in VAPI dashboard → Phone Numbers → your number → Server URL
# Set it to: https://<your-domain>/api/calls/webhook
VAPI_API_KEY=
VAPI_PHONE_NUMBER_ID=
VAPI_ASSISTANT_ID=
VAPI_AGENT_NAME=Hestia
VAPI_COMPANY_NAME=Hestia Events
VAPI_CALLBACK_NUMBER=
